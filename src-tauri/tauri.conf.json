{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreamVerse",
  "mainBinaryName": "streamverse",
  "version": "0.1.2",
  "identifier": "com.b1mango.streamverse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StreamVerse",
        "width": 1480,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: http: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../node_modules/ffmpeg-static/ffmpeg*": "bin/",
      "../registry/plugins.json": "registry/plugins.json",
      "target/release/streamverse-pack-*": "pack-binaries/",
      "gen/resources/download-engine/bin/*": "pack-resources/download-engine/bin/",
      "../scripts/douyin_bridge.py": "pack-resources/douyin-pack/scripts/douyin_bridge.py",
      "../vendor/douyin_api": "pack-resources/douyin-pack/vendor/douyin_api",
      "../scripts/bilibili_profile_bridge.py": "pack-resources/bilibili-pack/scripts/bilibili_profile_bridge.py",
      "../requirements-douyin-helper.txt": "pack-resources/browser-bridge/requirements-douyin-helper.txt",
      "../scripts/profile_browser_scan.py": "pack-resources/browser-bridge/scripts/profile_browser_scan.py"
    }
  }
}
