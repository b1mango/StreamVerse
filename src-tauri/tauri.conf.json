{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StreamVerse",
  "version": "0.1.0",
  "identifier": "com.b1mango.streamverse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StreamVerse",
        "width": 1480,
        "height": 980,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
